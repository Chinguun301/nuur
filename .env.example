# ==========================================
# Nuur - Environment Variables
# Copy this file to .env.local for local dev
# ==========================================

# --- Supabase (Required) ---
# Project URL and anon key from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (secret - NEVER expose to client/browser)
# Used by admin API routes and server actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site URL ---
# Used for canonical URLs, sitemap, and robots.txt
# In production this should be your Vercel deployment URL
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# --- GitHub (Optional) ---
# For displaying GitHub stats/contributions
NEXT_PUBLIC_GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-personal-access-token

# --- LeetCode (Optional) ---
# For displaying LeetCode stats
NEXT_PUBLIC_LEETCODE_USERNAME=your-leetcode-username

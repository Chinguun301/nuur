# Auto-detect text files and normalize line endings to LF in the repo
* text=auto

# Specific file types that should always have LF endings
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
